SECRET_KEY=change-this-to-a-long-random-string
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1
# Leave unset locally to use SQLite. Railway sets this automatically once a
# Postgres plugin is attached to the project.
DATABASE_URL=
# Comma-separated origins allowed to call this API (your Expo dev URL / app scheme).
CORS_ALLOWED_ORIGINS=http://localhost:19006

# Email — Resend SMTP relay (production only; console backend is used when DEBUG=True).
# EMAIL_HOST_PASSWORD  →  your Resend API key (re_...)
# DEFAULT_FROM_EMAIL   →  must be from a domain you've verified in Resend.
#                         During testing you can use: onboarding@resend.dev
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=noreply@yourdomain.com
