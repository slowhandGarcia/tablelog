# REQUIRED in production. Generate one with:
#   python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
# With DEBUG=False the app refuses to start if this is unset.
SECRET_KEY=change-this-to-a-long-random-string
# MUST be False in production. Leaving it True exposes debug tracebacks,
# disables secure cookies/HSTS/SSL-redirect, and opens ALLOWED_HOSTS + CORS.
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Optional API rate limits (defaults shown). Applied per user / per anon IP.
# THROTTLE_ANON=60/min
# THROTTLE_USER=300/min
# Leave unset locally to use SQLite. Railway sets this automatically once a
# Postgres plugin is attached to the project.
DATABASE_URL=
# Comma-separated origins allowed to call this API (your Expo dev URL / app scheme).
CORS_ALLOWED_ORIGINS=http://localhost:19006

# Email — Resend HTTP API via django-anymail (production only; console backend in DEBUG).
# Railway blocks SMTP ports, so anymail sends over HTTPS (port 443) instead.
# RESEND_API_KEY     →  your Resend API key (re_...)
# DEFAULT_FROM_EMAIL →  must match a domain verified in Resend.
#                       Defaults to noreply@table-log.com — only override if needed.
RESEND_API_KEY=
DEFAULT_FROM_EMAIL=noreply@table-log.com
# Receives admin "Contact Developers" submissions from the app.
DEV_CONTACT_EMAIL=you@example.com

# Base URL for email links. Must be https:// — email clients only make
# https:// links clickable. The backend serves HTML redirect pages at
# /auth/confirm-registration/ and /auth/reset-password/ that open the app.
# Production → your Railway domain (default; usually no need to override)
# Local dev  → your ngrok/Expo tunnel URL, e.g. https://xxxx.ngrok.io
FRONTEND_URL=https://tablelog-production.up.railway.app
